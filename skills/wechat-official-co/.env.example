# Just One API 认证 token：必须替换为你的真实 token
JUSTONE_API_TOKEN=your_token_here

# 可选：仅用于本机/私有服务器兜底。若 JUSTONE_API_TOKEN 未配置，会读取这个值。
# 不建议把真实 token 提交到 Git 仓库。

# 默认官方地址
JUSTONE_API_BASE_URL=https://api.justoneapi.com

# 国内服务器可尝试大陆地址，二选一即可
# JUSTONE_API_BASE_URL=http://47.117.133.51:30015

# 请求与限流策略
JUSTONE_TIMEOUT=75
JUSTONE_MAX_RETRIES=1
JUSTONE_DETAIL_MIN_INTERVAL_SECONDS=8

# 缓存策略
JUSTONE_DETAIL_CACHE_TTL_SECONDS=604800
JUSTONE_SEARCH_CACHE_TTL_SECONDS=21600
JUSTONE_CACHE_DIR=.cache/justone_wechat
